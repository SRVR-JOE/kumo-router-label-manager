# Helix Router Configuration
# Copy this file to .env and update with your settings

# Router connection settings
HLX_HOST=192.168.1.100
HLX_PORT=80
HLX_TIMEOUT=30
HLX_MAX_RETRIES=3
HLX_RETRY_DELAY=1.0

# Port configuration
HLX_MIN_PORT=1
HLX_MAX_PORT=32

# Logging configuration
LOG_LEVEL=INFO
LOG_FILE=helix_manager.log

# REST client settings
# HLX_REST_MAX_CONCURRENT_REQUESTS=32
# HLX_REST_REQUEST_TIMEOUT=4.0
# HLX_REST_CONNECT_TIMEOUT=3.0
# HLX_REST_KEEPALIVE_TIMEOUT=30

# Telnet client settings
# HLX_TELNET_CONNECT_TIMEOUT=3.0
# HLX_TELNET_COMMAND_TIMEOUT=2.0
# HLX_TELNET_COMMAND_DELAY=0.1

# Retry settings
# HLX_RETRY_MAX_ATTEMPTS=2
# HLX_RETRY_BACKOFF_BASE=0.3
# HLX_RETRY_BACKOFF_MULTIPLIER=2.0

# Protocol port settings
# HLX_VIDEOHUB_PORT=9990
# HLX_LIGHTWARE_PORT=6107

# File paths
DEFAULT_DOWNLOAD_PATH=./downloads
DEFAULT_UPLOAD_PATH=./uploads
