# KUMO Router Configuration
# Copy this file to .env and update with your settings

# Router connection settings
KUMO_HOST=192.168.1.100
KUMO_PORT=80
KUMO_TIMEOUT=30
KUMO_MAX_RETRIES=3
KUMO_RETRY_DELAY=1.0

# Port configuration
KUMO_MIN_PORT=1
KUMO_MAX_PORT=32

# Logging configuration
LOG_LEVEL=INFO
LOG_FILE=kumo_manager.log

# REST client settings
# KUMO_REST_MAX_CONCURRENT_REQUESTS=32
# KUMO_REST_REQUEST_TIMEOUT=4.0
# KUMO_REST_CONNECT_TIMEOUT=3.0
# KUMO_REST_KEEPALIVE_TIMEOUT=30

# Telnet client settings
# KUMO_TELNET_CONNECT_TIMEOUT=3.0
# KUMO_TELNET_COMMAND_TIMEOUT=2.0
# KUMO_TELNET_COMMAND_DELAY=0.1

# Retry settings
# KUMO_RETRY_MAX_ATTEMPTS=2
# KUMO_RETRY_BACKOFF_BASE=0.3
# KUMO_RETRY_BACKOFF_MULTIPLIER=2.0

# Protocol port settings
# KUMO_VIDEOHUB_PORT=9990
# KUMO_LIGHTWARE_PORT=6107

# File paths
DEFAULT_DOWNLOAD_PATH=./downloads
DEFAULT_UPLOAD_PATH=./uploads
